<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/flPrologueRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1A"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_2xl"
        android:paddingEnd="@dimen/space_2xl">

        <TextView
            android:id="@+id/tvPrologueEra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:gravity="center"
            android:textColor="@color/gold"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPrologueMatchup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:alpha="0"
            android:gravity="center"
            android:textColor="@color/text"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPrologueBlue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:alpha="0"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/blue"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvPrologueRed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:alpha="0"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/red"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvPrologueTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:alpha="0"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/muted"
            android:textSize="@dimen/text_sm" />

        <TextView
            android:id="@+id/tvPrologueClosing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:alpha="0"
            android:gravity="center"
            android:textColor="@color/gold"
            android:textSize="@dimen/text_lg"
            android:textStyle="italic" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPrologueSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/space_lg"
        android:alpha="0.72"
        android:text="@string/prologue_skip_hint"
        android:textColor="@color/muted"
        android:textSize="@dimen/text_xs" />
</FrameLayout>
